# Copia este archivo como .env si quieres cambiar puertos o credenciales.
# Estos valores son para ambiente local de practica. No usarlos en produccion.

COMPOSE_PROJECT_NAME=campuslands-dev-nosql-mongodb
DOCS_PORT=8080
MONGO_PORT=27017
MONGO_EXPRESS_PORT=8081

MONGO_INITDB_ROOT_USERNAME=campus_admin
MONGO_INITDB_ROOT_PASSWORD=campus_admin_123
MONGO_INITDB_DATABASE=campuslands

MONGO_APP_DATABASE=campuslands
MONGO_APP_USERNAME=campus_student
MONGO_APP_PASSWORD=campus_student_123

MONGO_EXPRESS_USERNAME=campus
MONGO_EXPRESS_PASSWORD=campus_123
